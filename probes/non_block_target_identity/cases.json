      "preview fields",
      "summary_text fields",
      "etag fields",
      "manifest-owned span literals",
      "handwritten parsing"
    ]
  },
  "candidates": [
    {
      "name": "content_only",
      "decision_gate": "accept when the current target_bytes selected by current_target_query reproduce the observed target_bytes token",
      "framing": "non-block-target-identity-token + u64be(len(schema_version)) + schema_version + u64be(len(candidate_name)) + candidate_name + u64be(len(surface)) + surface + u64be(len(target_bytes)) + target_bytes"
    },
    {
      "name": "target_local",
      "decision_gate": "accept when the current canonical descriptor and current target_bytes reproduce the observed token",
      "framing": "non-block-target-identity-token + u64be(len(schema_version)) + schema_version + u64be(len(candidate_name)) + candidate_name + u64be(len(surface)) + surface + u64be(len(canonical_descriptor_utf8)) + canonical_descriptor_utf8 + u64be(len(target_bytes)) + target_bytes"
    },
    {
      "name": "ambiguity_reject",
      "decision_gate": "accept only when the current target_bytes selected by current_target_query reproduce the observed token and exactly one current-domain exact-byte match exists",
      "framing": "non-block-target-identity-token + u64be(len(schema_version)) + schema_version + u64be(len(candidate_name)) + candidate_name + u64be(len(surface)) + surface + u64be(len(target_bytes)) + target_bytes"
    },
    {
      "name": "document_target_state",
      "decision_gate": "accept when the current canonical descriptor, current target_bytes, and current document_bytes reproduce the observed token",
      "framing": "non-block-target-identity-token + u64be(len(schema_version)) + schema_version + u64be(len(candidate_name)) + candidate_name + u64be(len(surface)) + surface + u64be(len(canonical_descriptor_utf8)) + canonical_descriptor_utf8 + u64be(len(target_bytes)) + target_bytes + u64be(len(document_bytes)) + document_bytes"
    }
  ],

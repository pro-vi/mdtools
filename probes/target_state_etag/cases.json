      "current_domain_query": {
        "type": "blocks_domain",
        "surface": "block",
        "command": "md blocks FILE --json"
      },
      "notes": "This is the explicit false-conflict case for document-wide binding when the target bytes are unchanged.",
      "expected": {
        "content_only": { "decision": "accept", "credit": "correct" },
        "target_local": { "decision": "accept", "credit": "correct" },
        "ambiguity_reject": { "decision": "accept", "credit": "correct" },
        "document_target_state": { "decision": "reject", "credit": "false-conflict" }
      }
    },

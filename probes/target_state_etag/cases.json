        "block_index": 2
      },
      "current_target_query": {
        "type": "block_target",
        "surface": "block",
        "command": "md blocks FILE --json",
        "block_index": 2
      },
      "current_domain_query": {
        "type": "blocks_domain",
        "surface": "block",
        "command": "md blocks FILE --json"
      },
      "same_locator_preconditions": {
        "require_target_bytes_equal": true,
        "require_canonical_descriptor_equal": true,
        "require_current_match_count": 1,
        "require_document_bytes_different": true,
        "mechanical_failure_on_violation": true
      },
      "notes": "The observed query selects the first of two identical duplicate blocks; the current query selects the surviving second duplicate after the first duplicate is removed and the survivor shifts into the same canonical block locator.",
      "expected": {
        "content_only": { "decision": "accept", "credit": "wrong_identity" },
        "target_local": { "decision": "accept", "credit": "wrong_identity" },
        "ambiguity_reject": { "decision": "accept", "credit": "wrong_identity" },
        "document_target_state": { "decision": "reject", "credit": "correct" }
      }
    },
    {
      "case_id": "block-unrelated-edit-false-conflict",
      "case_class": "unrelated_edit_after_unchanged_target",
      "identity_truth": "same_target",
      "surface": "block",
      "observed_document_utf8": "# Doc\n\nstable token\n\nnotes\n",
      "current_document_utf8": "# Doc\n\nstable token\n\nnotes updated elsewhere\n",

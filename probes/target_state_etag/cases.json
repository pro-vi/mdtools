{
  "schema_version": "target-state-etag.v2",
  "manifest_kind": "deterministic-query-matrix",
  "date_locked": "2026-07-18",
  "case_id_regex": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
  "descriptor_contract": {
    "block": ["index", "span"],
    "section": ["selector", "heading", "span"],
    "table": ["block_index", "span"],
    "task": ["loc", "child_path", "span"]
  },
  "target_bytes_contract": {
    "source": "slice temporary document raw bytes by resolved span.byte_start..span.byte_end",
    "forbidden_authority": [
      "returned content strings",
      "preview fields",
      "summary_text fields",
      "etag fields",
      "manifest-owned span literals",
      "handwritten parsing"
    ]
  },
  "candidates": [
    {
      "name": "content_only",
      "decision_gate": "accept when at least one current-domain exact-byte match reproduces the observed target_bytes token",
      "framing": "target-state-etag-token + u64be(len(schema_version)) + schema_version + u64be(len(candidate_name)) + candidate_name + u64be(len(surface)) + surface + u64be(len(target_bytes)) + target_bytes"
    },
    {
      "name": "target_local",
      "decision_gate": "accept when the current canonical descriptor and current target_bytes reproduce the observed token",
      "framing": "target-state-etag-token + u64be(len(schema_version)) + schema_version + u64be(len(candidate_name)) + candidate_name + u64be(len(surface)) + surface + u64be(len(canonical_descriptor_utf8)) + canonical_descriptor_utf8 + u64be(len(target_bytes)) + target_bytes"
    },
    {
      "name": "ambiguity_reject",
      "decision_gate": "accept only when exactly one current-domain exact-byte match exists and the target_bytes token reproduces the observed token",
      "framing": "target-state-etag-token + u64be(len(schema_version)) + schema_version + u64be(len(candidate_name)) + candidate_name + u64be(len(surface)) + surface + u64be(len(target_bytes)) + target_bytes"
    },
    {
      "name": "document_target_state",
      "decision_gate": "accept when the current canonical descriptor, current target_bytes, and current document_bytes reproduce the observed token",
      "framing": "target-state-etag-token + u64be(len(schema_version)) + schema_version + u64be(len(candidate_name)) + candidate_name + u64be(len(surface)) + surface + u64be(len(canonical_descriptor_utf8)) + canonical_descriptor_utf8 + u64be(len(target_bytes)) + target_bytes + u64be(len(document_bytes)) + document_bytes"
    }
  ],
  "query_shapes": {
    "block_target": {
      "surface": "block",
      "command": "md blocks FILE --json",
      "required_keys": ["type", "surface", "command", "block_index"]
    },
    "blocks_domain": {
      "surface": "block",
      "command": "md blocks FILE --json",
      "required_keys": ["type", "surface", "command"]
    },
    "section_target": {
      "surface": "section",
      "command": "md section SELECTOR FILE --occurrence N --json",
      "required_keys": [
        "type",
        "surface",
        "command",
        "selector",
        "occurrence",
        "contains",
        "ignore_case"
      ]
    },
    "section_domain": {
      "surface": "section",
      "command": "md section SELECTOR FILE --occurrence N --json",
      "required_keys": [
        "type",
        "surface",
        "command",
        "selector",
        "contains",
        "ignore_case",
        "occurrence_start",
        "enumerate_until_missing"
      ]
    },
    "table_target": {
      "surface": "table",
      "command": "md table FILE --index BLOCK_INDEX --json",
      "required_keys": ["type", "surface", "command", "block_index"]
    },
    "tables_domain": {
      "surface": "table",
      "command": "md table FILE --json",
      "required_keys": ["type", "surface", "command"]
    },
    "task_target": {
      "surface": "task",
      "command": "md tasks FILE --json",
      "required_keys": ["type", "surface", "command", "result_index", "task_index"]
    },
    "tasks_domain": {
      "surface": "task",
      "command": "md tasks FILE --json",
      "required_keys": ["type", "surface", "command", "result_index"]
    }
  },
  "required_case_ids": [
    "block-unchanged-reread",
    "block-duplicate-cross-target-copy",
    "block-same-locator-duplicate-shift",
    "block-unrelated-edit-false-conflict",
    "block-exact-byte-reversion",
    "block-unchanged-crlf-bytes",
    "block-unchanged-multibyte-utf8-bytes",
    "section-unchanged-real-descriptor",
    "table-unchanged-real-descriptor",
    "task-unchanged-real-descriptor"
  ],
  "cases": [
    {
      "case_id": "block-unchanged-reread",
      "case_class": "unchanged_reread",
      "identity_truth": "same_target",
      "surface": "block",
      "observed_document_utf8": "# Doc\n\nalpha block\n\n## Next\nbody\n",
      "current_document_utf8": "# Doc\n\nalpha block\n\n## Next\nbody\n",
      "observed_target_query": {
        "type": "block_target",
        "surface": "block",
        "command": "md blocks FILE --json",
        "block_index": 1
      },
      "current_target_query": {
        "type": "block_target",
        "surface": "block",
        "command": "md blocks FILE --json",
        "block_index": 1
      },
      "current_domain_query": {
        "type": "blocks_domain",
        "surface": "block",
        "command": "md blocks FILE --json"
      },
      "expected": {
        "content_only": { "decision": "accept", "credit": "correct" },
        "target_local": { "decision": "accept", "credit": "correct" },
        "ambiguity_reject": { "decision": "accept", "credit": "correct" },
        "document_target_state": { "decision": "accept", "credit": "correct" }
      }
    },
    {
      "case_id": "block-duplicate-cross-target-copy",
      "case_class": "duplicate_cross_target_copy",
      "identity_truth": "wrong_target",
      "surface": "block",
      "observed_document_utf8": "# Doc\n\nstable token\n\nmoved elsewhere\n",
      "current_document_utf8": "# Doc\n\nmutated target\n\nstable token\n",
      "observed_target_query": {
        "type": "block_target",
        "surface": "block",
        "command": "md blocks FILE --json",
        "block_index": 1
      },
      "current_target_query": {
        "type": "block_target",
        "surface": "block",
        "command": "md blocks FILE --json",
        "block_index": 2
      },
      "current_domain_query": {
        "type": "blocks_domain",
        "surface": "block",
        "command": "md blocks FILE --json"
      },
      "notes": "The observed bytes survive only as a copied block at a different index in the current document.",
      "expected": {
        "content_only": { "decision": "accept", "credit": "wrong_identity" },
        "target_local": { "decision": "reject", "credit": "correct" },
        "ambiguity_reject": { "decision": "accept", "credit": "wrong_identity" },
        "document_target_state": { "decision": "reject", "credit": "correct" }
      }
    },
    {
      "case_id": "block-same-locator-duplicate-shift",
      "case_class": "same_locator_duplicate_shift",
      "identity_truth": "wrong_target",
      "surface": "block",
      "observed_document_utf8": "# Doc\n\nanchor\n\nstable token\n\nstable token\n",
      "current_document_utf8": "# Doc\n\nanchor\n\nstable token\n",
      "observed_target_query": {
        "type": "block_target",
        "surface": "block",
